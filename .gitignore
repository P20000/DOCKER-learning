# Local .terraform directories and cache
.terraform/
.terraform.lock.hcl

# State files and backups
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude sensitive variables files
*.tfvars
*.tfvars.json

# Exclude local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Exclude CLI config files
.terraformrc
terraform.rc

# Exclude generated SSH private keys
*.pem
